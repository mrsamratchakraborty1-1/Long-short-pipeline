      "source": [
        "# Path to the LM 10-X Summaries CSV (download from SRAF; ~188MB).\n",
        "# Leave as-is to attempt auto-handling; if the file is not present and the\n",
        "# network is blocked, sentiment features fall back to NaN (dropped in cleaning).\n",
        "LM_CSV_PATH = \"/content/drive/MyDrive/Loughran-McDonald_10X_Summaries_1993-2025.csv\"\n",
        "\n",
        "SENT_FEATURES = [\"sent_neg_pct\", \"sent_pos_pct\", \"sent_unc_pct\",\n",
        "                 \"sent_lit_pct\", \"sent_nettone\"]   # NEW (tutor comment 3 / Ed #34)\n",
        "\n",
        "import os, json as _json\n",
        "\n",
        "def build_ticker_cik_bridge(tickers):\n",
        "    \"\"\"Map tickers -> CIK via SEC company_tickers.json (free, no key).\"\"\"\n",
        "    url = \"https://www.sec.gov/files/company_tickers.json\"\n",
        "    try:\n",
        "        req = urllib.request.Request(url, headers={\"User-Agent\": \"FINC6028 student project contact@uni.edu\"})\n",
        "        with urllib.request.urlopen(req, timeout=20) as r:\n",
        "            d = _json.loads(r.read().decode())\n",
        "        rows = [{\"ticker\": v[\"ticker\"], \"cik\": int(v[\"cik_str\"])} for v in d.values()]\n",
        "        bridge = pd.DataFrame(rows)\n",
        "        bridge = bridge[bridge[\"ticker\"].isin(tickers)].drop_duplicates(\"ticker\")\n",
        "        return bridge\n",
        "    except Exception as e:\n",
        "        print(f\"  [warn] SEC ticker->CIK bridge failed ({e}).\")\n",
        "        return pd.DataFrame(columns=[\"ticker\", \"cik\"])\n",
        "\n",
        "def _norm_col(s):\n",
        "    import re\n",
        "    return re.sub(r\"[^a-z0-9]\", \"\", str(s).lower())\n",
        "\n",
        "def resolve_lm_columns(cols):\n",
        "    \"\"\"Map needed fields to whatever the SRAF file actually calls them (header names\n",
        "    vary across SRAF releases). Returns (resolved dict, missing list).\"\"\"\n",
        "    norm_map = {_norm_col(c): c for c in cols}\n",
        "    wanted = {\n",
        "        \"CIK\":         [\"cik\"],\n",
        "        \"FILING_DATE\": [\"filingdate\", \"filedate\", \"datefiled\", \"date\"],\n",
        "        \"N_Words\":     [\"nwords\", \"wordcount\", \"words\", \"ntotalwords\", \"totalwords\"],\n",
        "        \"Negative\":    [\"negative\", \"lmnegative\", \"negcount\", \"finneg\"],\n",
        "        \"Positive\":    [\"positive\", \"lmpositive\", \"poscount\", \"finpos\"],\n",
        "        \"Uncertainty\": [\"uncertainty\", \"lmuncertainty\", \"uncertain\"],\n",
        "        \"Litigious\":   [\"litigious\", \"lmlitigious\"],\n",
        "        \"N_Negation\":  [\"nnegation\", \"negation\", \"numnegation\", \"ofnegation\", \"nnegations\"],\n",
        "    }\n",
        "    resolved, missing = {}, []\n",
        "    for canon, cands in wanted.items():\n",
        "        hit = next((norm_map[c] for c in cands if c in norm_map), None)\n",
        "        if hit is None:   # fallback: substring match\n",
        "            hit = next((actual for ncol, actual in norm_map.items()\n",
        "                        if any(c in ncol for c in cands)), None)\n",
        "        (resolved.__setitem__(canon, hit) if hit else missing.append(canon))\n",
        "    return resolved, missing\n",
        "\n",
        "def load_lm_sentiment(csv_path, bridge):\n",
        "    \"\"\"Load LM 10-X Summaries, auto-resolving column names (SRAF headers vary by\n",
        "    release), then build standardised tone features. Net tone uses N_Negation per\n",
        "    Ed post #34 tip; if that column is absent we fall back to Positive-only net tone.\"\"\"\n",
        "    if bridge.empty:\n",
        "        return pd.DataFrame(columns=[\"ticker\", \"fdate\"] + SENT_FEATURES)\n",
        "    try:\n",
        "        lm = pd.read_csv(csv_path)   # read all columns; resolve names below\n",
        "    except Exception as e:\n",
        "        print(f\"  [warn] LM CSV not loaded ({e}); sentiment will be NaN.\")\n",
        "        return pd.DataFrame(columns=[\"ticker\", \"fdate\"] + SENT_FEATURES)\n",
        "\n",
        "    col, missing = resolve_lm_columns(lm.columns)\n",
        "    print(f\"  LM columns detected: {col}\")\n",
        "    # Required minimum: CIK, FILING_DATE, N_Words + the four count columns\n",
        "    required = [\"CIK\", \"FILING_DATE\", \"N_Words\", \"Negative\", \"Positive\",\n",
        "                \"Uncertainty\", \"Litigious\"]\n",
        "    hard_missing = [c for c in required if c not in col]\n",
        "    if hard_missing:\n",
        "        print(f\"  [warn] LM file missing required columns {hard_missing}; \"\n",
        "              f\"available headers: {list(lm.columns)[:15]} ...\")\n",
        "        print(\"         -> sentiment disabled (will run without it).\")\n",
        "        return pd.DataFrame(columns=[\"ticker\", \"fdate\"] + SENT_FEATURES)\n",
        "\n",
        "    lm = lm.rename(columns={v: k for k, v in col.items()})\n",
        "    lm = lm[lm[\"N_Words\"] > 0].copy()\n",
        "    # FILING_DATE may be YYYYMMDD int or a parseable string\n",
        "    fd = lm[\"FILING_DATE\"]\n",
        "    lm[\"fdate\"] = pd.to_datetime(fd.astype(str).str.replace(r\"\\.0$\", \"\", regex=True),\n",
        "                                 format=\"%Y%m%d\", errors=\"coerce\")\n",
        "    lm.loc[lm[\"fdate\"].isna(), \"fdate\"] = pd.to_datetime(\n",
        "        fd[lm[\"fdate\"].isna()], errors=\"coerce\")\n",
        "\n",
        "    lm[\"sent_neg_pct\"] = lm[\"Negative\"]    / lm[\"N_Words\"]\n",
        "    lm[\"sent_pos_pct\"] = lm[\"Positive\"]    / lm[\"N_Words\"]\n",
        "    lm[\"sent_unc_pct\"] = lm[\"Uncertainty\"] / lm[\"N_Words\"]\n",
        "    lm[\"sent_lit_pct\"] = lm[\"Litigious\"]   / lm[\"N_Words\"]\n",
        "    if \"N_Negation\" in col:\n",
        "        lm[\"sent_nettone\"] = (lm[\"Positive\"] - lm[\"N_Negation\"]) / lm[\"N_Words\"]\n",
        "    else:\n",
        "        print(\"  [info] N_Negation column not found; net tone = Positive/N_Words \"\n",
        "              \"(no negation adjustment).\")\n",
        "        lm[\"sent_nettone\"] = lm[\"Positive\"] / lm[\"N_Words\"]\n",
        "\n",
        "    lm[\"CIK\"] = pd.to_numeric(lm[\"CIK\"], errors=\"coerce\")\n",
        "    lm = lm.merge(bridge, left_on=\"CIK\", right_on=\"cik\", how=\"inner\")\n",
        "    return (lm[[\"ticker\", \"fdate\"] + SENT_FEATURES]\n",
        "            .dropna(subset=[\"fdate\"]).sort_values([\"ticker\", \"fdate\"]))\n",
        "\n",
        "def asof_merge_sentiment(panel, lm):\n",
        "    \"\"\"Point-in-time as-of merge: each (date,ticker) gets the most recent filing\n",
        "    on or before that date. No look-ahead.\"\"\"\n",
        "    if lm.empty:\n",
        "        for c in SENT_FEATURES: panel[c] = np.nan\n",
        "        return panel\n",
        "    out = []\n",
        "    for tk, g in panel.groupby(\"ticker\"):\n",
        "        g = g.sort_values(\"date\").reset_index(drop=True)\n",
        "        lf = lm[lm[\"ticker\"] == tk].sort_values(\"fdate\").reset_index(drop=True)\n",
        "        if lf.empty:\n",
        "            for c in SENT_FEATURES: g[c] = np.nan\n",
        "            out.append(g); continue\n",
        "        out.append(pd.merge_asof(g, lf.drop(columns=[\"ticker\"]),\n",
        "                                 left_on=\"date\", right_on=\"fdate\",\n",
        "                                 direction=\"backward\"))\n",
        "    return pd.concat(out, ignore_index=True)\n",
        "\n",
        "print(\"Building sentiment features (LM 10-X) ...\")\n",
        "bridge = build_ticker_cik_bridge(TICKERS)\n",
        "print(f\"  ticker->CIK bridge: {len(bridge)} of {len(TICKERS)} tickers mapped\")\n",
        "lm_sent = load_lm_sentiment(LM_CSV_PATH, bridge) if os.path.exists(LM_CSV_PATH) \\\n",
        "          else load_lm_sentiment(LM_CSV_PATH, bridge)  # triggers warn+fallback if absent\n",
        "if lm_sent.empty:\n",
        "    print(\"  [info] No sentiment data available -> features will be NaN and dropped.\")\n",
        "    print(\"         To enable: download the SRAF CSV (Ed #34) and set LM_CSV_PATH.\")\n",
        "else:\n",
        "    print(f\"  LM filings matched to universe: {len(lm_sent):,} rows, \"\n",
        "          f\"{lm_sent['ticker'].nunique()} tickers\")"
