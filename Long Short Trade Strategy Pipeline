        "def ann_return(r):  return (1 + r).prod() ** (52 / len(r)) - 1\n",
        "def ann_vol(r):     return r.std() * np.sqrt(52)\n",
        "def sharpe(r, rf=0.0):\n",
        "    v = ann_vol(r); return (ann_return(r) - rf) / v if v > 0 else np.nan\n",
        "def max_drawdown(r):\n",
        "    w = (1 + r).cumprod(); return (w / w.cummax() - 1).min()\n",
        "\n",
        "def tear_sheet(s_gross, s_net, s_to, name=\"\"):\n",
        "    return {\"Name\": name,\n",
        "            \"AnnRet_gross\": ann_return(s_gross), \"AnnVol_gross\": ann_vol(s_gross),\n",
        "            \"Sharpe_gross\": sharpe(s_gross),     \"MDD_gross\": max_drawdown(s_gross),\n",
        "            \"AnnRet_net\": ann_return(s_net),     \"AnnVol_net\": ann_vol(s_net),\n",
        "            \"Sharpe_net\": sharpe(s_net),         \"MDD_net\": max_drawdown(s_net),\n",
        "            \"AvgTurnover\": s_to.mean()}\n",
        "\n",
        "def build_weights(scores, q=0.2, long_short=True):\n",
        "    \"\"\"Equal-weight top-q long, bottom-q short. NO position cap (tutor comment 2).\"\"\"\n",
        "    n_cut = max(1, int(np.floor(len(scores) * q)))\n",
        "    s = scores.sort_values()\n",
        "    longs, shorts = s.tail(n_cut).index, s.head(n_cut).index\n",
        "    w = pd.Series(0.0, index=scores.index)\n",
        "    if len(longs):  w[longs] = 1.0 / len(longs)\n",
        "    if long_short and len(shorts): w[shorts] = -1.0 / len(shorts)\n",
        "    return w\n",
        "\n",
        "def turnover_one_way(w_new, w_prev_plus):\n",
        "    idx = sorted(set(w_new.index).union(w_prev_plus.index))\n",
        "    return 0.5 * np.abs(w_new.reindex(idx).fillna(0) -\n",
        "                        w_prev_plus.reindex(idx).fillna(0)).sum()\n",
        "\n",
        "def drift_weights(w_prev, r_hold):\n",
        "    idx = sorted(set(w_prev.index).union(r_hold.index))\n",
        "    w0 = w_prev.reindex(idx).fillna(0); r = r_hold.reindex(idx).fillna(0)\n",
        "    gt = np.abs(w0).sum(); hold = w0 * (1 + r); gn = np.abs(hold).sum()\n",
        "    return w0 if gn == 0 else hold / gn * gt\n",
        "\n",
        "print(\"Helpers defined (no position-cap function).\")"
      ]
