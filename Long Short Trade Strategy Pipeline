        "}\n",
        "feature_table = pd.DataFrame(\n",
        "    [(f, *FEATURE_META[f]) for f in FEATURES if f in FEATURE_META],\n",
        "    columns=[\"Feature\", \"Group\", \"Definition\", \"Available at\", \"Academic basis\"])\n",
        "print(\"--- Feature dictionary ---\")\n",
        "display(feature_table)\n",
        "\n",
        "print(\"\\nLEAKAGE CONTROL STATEMENT\")\n",
        "print(\"  * All price/volume features use data available at or before the Friday close of t.\")\n",
        "print(\"  * Macro features (VIX, slope) are forward-filled then read at week t only.\")\n",
        "print(\"  * Cross-sectional ranks use contemporaneous (t) values across names; no t+1 info.\")\n",
        "print(\"  * Sentiment uses an as-of merge: a filing is attached only to weeks ON OR AFTER its\")\n",
        "print(\"    filing date, then forward-filled until the next filing -> strictly point-in-time.\")\n",
        "print(\"  * Target uses ret_fwd1 via shift(-1) within each ticker group (no cross-date bleed).\")\n",
        "print(\"  * The cross-sectional MEDIAN in the target is label construction, not a feature.\")\n",
        "print(\"  * StandardScaler is fit ONLY on each training window inside the sklearn Pipeline.\")\n",
        "\n",
