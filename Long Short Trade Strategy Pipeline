      "source": [
        "## 5. Feature engineering\n",
        "\n",
        "**Timing convention:** every feature uses information available at the **end of week t\n",
        "(Friday close)**. The target is the return realised **during week t+1**. The portfolio is\n",
        "formed at the close of t and held through t+1.\n",
        "\n",
        "**Feature set expanded from 6 → 15 (tutor comment 3).** The original six price/volume\n",
        "features are retained; we add two macro regime features (VIX, yield slope), two\n",
        "cross-sectional features (return rank, vol rank within each week), and five\n",
        "Loughran-McDonald 10-K/10-Q **sentiment** features (negative/positive/uncertainty/litigious\n",
        "tone shares plus a net-tone measure). Sentiment is the new *information source* the tutor\n",
        "asked for; macro and cross-sectional features add regime and relative-ranking context."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "eKvb9jisI_Mg",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "eKvb9jisI_Mg",
        "outputId": "4fdd45ee-e949-4570-e9ae-6b6e28c01e13"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Features (15): ['mom_12w', 'mom_26w_skip1', 'high52_ratio', 'idiovol_8w', 'amihud_4w', 'vol_trend_4_12', 'vix', 'yield_slope', 'ret_rank_xsec', 'idiovol_rank_xsec', 'sent_neg_pct', 'sent_pos_pct', 'sent_unc_pct', 'sent_lit_pct', 'sent_nettone']\n"
          ]
        }
      ],
      "source": [
        "PRICE_FEATURES = [\"mom_12w\", \"mom_26w_skip1\", \"high52_ratio\",\n",
        "                  \"idiovol_8w\", \"amihud_4w\", \"vol_trend_4_12\"]\n",
        "MACRO_FEATURES = [\"vix\", \"yield_slope\"]                 # NEW (tutor comment 3)\n",
        "XSEC_FEATURES  = [\"ret_rank_xsec\", \"idiovol_rank_xsec\"] # NEW (tutor comment 3)\n",
        "# SENT_FEATURES defined in Section 3b  (NEW; tutor comment 3 / Ed #34)\n",
        "FEATURES = PRICE_FEATURES + MACRO_FEATURES + XSEC_FEATURES + SENT_FEATURES\n",
        "\n",
        "\n",
        "def add_features(df, spy_ret, macro, lm_sent):\n",
        "    df = df.copy()\n",
        "\n",
        "    # SPY weekly return for idiosyncratic-vol residual\n",
        "    spy_df = spy_ret.reset_index(); spy_df.columns = [\"date\", \"spy_ret\"]\n",
        "    df = df.merge(spy_df, on=\"date\", how=\"left\")\n",
        "\n",
        "    g = df.groupby(\"ticker\", group_keys=False)\n",
        "\n",
        "    # ── 1. 12-week momentum (Jegadeesh & Titman 1993) ───────────────────────\n",
        "    df[\"mom_12w\"] = g[\"ret\"].apply(lambda x: x.rolling(12, min_periods=12).sum())\n",
        "\n",
        "    # ── 2. 26-week momentum, skip most-recent week (avoid short-term reversal) ─\n",
        "    df[\"mom_26w_skip1\"] = g[\"ret\"].apply(\n",
        "        lambda x: x.shift(1).rolling(25, min_periods=25).sum())\n",
        "\n",
        "    # ── 3. 52-week-high ratio (George & Hwang 2004) ─────────────────────────\n",
        "    df[\"high52_ratio\"] = g[\"price\"].apply(\n",
        "        lambda x: x / x.rolling(52, min_periods=26).max())\n",
        "\n",
        "    # ── 4. Idiosyncratic vol, 8w (Ang et al. 2006) ──────────────────────────\n",
        "    df[\"resid_ret\"]  = df[\"ret\"] - df[\"spy_ret\"].fillna(0.0)\n",
        "    df[\"idiovol_8w\"] = g[\"resid_ret\"].apply(lambda x: x.rolling(8, min_periods=8).std())\n",
        "\n",
        "    # ── 5. Amihud illiquidity, 4w (Amihud 2002) ─────────────────────────────\n",
        "    df[\"dollar_vol\"] = df[\"price\"] * df[\"volume\"]\n",
        "    df[\"amihud_raw\"] = df[\"ret\"].abs() / df[\"dollar_vol\"].replace(0, np.nan)\n",
        "    df[\"amihud_4w\"]  = g[\"amihud_raw\"].apply(\n",
        "        lambda x: np.log1p(x.rolling(4, min_periods=4).mean() * 1e9))\n",
        "\n",
        "    # ── 6. Volatility trend, 4w/12w (practitioner regime indicator) ─────────\n",
        "    vol_4w  = g[\"ret\"].apply(lambda x: x.rolling(4,  min_periods=4).std())\n",
        "    vol_12w = g[\"ret\"].apply(lambda x: x.rolling(12, min_periods=12).std())\n",
        "    df[\"vol_trend_4_12\"] = vol_4w / vol_12w.replace(0, np.nan)\n",
        "\n",
        "    # ── 7-8. Macro regime features (NEW; tutor comment 3) ───────────────────\n",
        "    m = macro.reset_index()\n",
        "    df = df.merge(m, on=\"date\", how=\"left\")\n",
        "    df[\"vix\"]         = df.groupby(\"ticker\")[\"vix\"].ffill()\n",
        "    df[\"yield_slope\"] = df.groupby(\"ticker\")[\"yield_slope\"].ffill()\n",
        "\n",
        "    # ── 9-10. Cross-sectional rank features (NEW; tutor comment 3) ──────────\n",
        "    # Rank within each week -> in [0,1]. Uses only contemporaneous (t) data,\n",
        "    # so no look-ahead. Helps the model rank relative to peers.\n",
        "    df[\"ret_rank_xsec\"]     = df.groupby(\"date\")[\"mom_12w\"].rank(pct=True)\n",
        "    df[\"idiovol_rank_xsec\"] = df.groupby(\"date\")[\"idiovol_8w\"].rank(pct=True)\n",
        "\n",
        "    # ── 11-15. Sentiment features (NEW; tutor comment 3 / Ed #34) ───────────\n",
        "    # Point-in-time as-of merge handled in Section 3b's asof_merge_sentiment.\n",
        "    df = asof_merge_sentiment(df, lm_sent)\n",
        "    # Forward-fill within ticker so weeks between filings carry the last filing,\n",
        "    # but only AFTER a filing has occurred (merge_asof guarantees no look-ahead).\n",
        "    for c in SENT_FEATURES:\n",
        "        if c in df.columns:\n",
        "            df[c] = df.groupby(\"ticker\")[c].ffill()\n",
        "    # Neutral imputation for weeks BEFORE a firm's first filing (or unmatched\n",
        "    # tickers): fill remaining sentiment NaNs with the cross-sectional median of\n",
        "    # that feature on that date. This preserves price-feature history instead of\n",
        "    # dropping years of rows, and uses only contemporaneous (t) info -> no leakage.\n",
        "    # (If sentiment is entirely absent, these columns stay NaN and are excluded\n",
        "    #  from FEATURES by the guard in Section 6.)\n",
        "    if not lm_sent.empty:\n",
        "        for c in SENT_FEATURES:\n",
        "            if c in df.columns:\n",
        "                xmed_c = df.groupby(\"date\")[c].transform(\"median\")\n",
        "                df[c] = df[c].fillna(xmed_c)\n",
        "\n",
        "    # ── Target ───────────────────────────────────────────────────────────────\n",
        "    # CRITICAL: asof_merge_sentiment above did a pd.concat that REORDERED rows,\n",
        "    # so the earlier `g` groupby is now stale. We MUST re-sort and regroup here,\n",
        "    # or ret_fwd1 will be misaligned across tickers (a lookahead leak).\n",
        "    df = df.sort_values([\"ticker\", \"date\"]).reset_index(drop=True)\n",
        "    g = df.groupby(\"ticker\", group_keys=False)              # FRESH groupby\n",
        "    df[\"ret_fwd1\"] = g[\"ret\"].shift(-1)          # return during t+1\n",
        "    if TARGET_MODE == \"median\":\n",
        "        xmed = df.groupby(\"date\")[\"ret_fwd1\"].transform(\"median\")\n",
        "        df[\"target_up\"] = (df[\"ret_fwd1\"] > xmed).astype(\"float\")\n",
        "    else:\n",
        "        df[\"target_up\"] = (df[\"ret_fwd1\"] > 0).astype(\"float\")\n",
        "\n",
        "    drop = [\"spy_ret\", \"resid_ret\", \"dollar_vol\", \"amihud_raw\", \"fdate\"]\n",
        "    return df.drop(columns=[c for c in drop if c in df.columns])\n",
        "\n",
        "df_feat = add_features(df_raw, benchmark_ret, macro, lm_sent)\n",
        "print(f\"Features ({len(FEATURES)}): {FEATURES}\")"
      ]
