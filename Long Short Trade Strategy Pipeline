        "# =============================================================================\n",
        "#  SUMMARY STATISTICS  —  drop into the notebook as a NEW cell\n",
        "#  (run after `data` and `FEATURES` exist; prints two LaTeX tables)\n",
        "# -----------------------------------------------------------------------------\n",
        "#  Produces:\n",
        "#   (1) Per-feature descriptive stats (mean, sd, min, median, max) on the\n",
        "#       cleaned out-of-sample panel.\n",
        "#   (2) Universe coverage by GICS sector (count of names + avg names/week).\n",
        "#  Both print as booktabs LaTeX you can paste straight into the report.\n",
        "# =============================================================================\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "# ---------- (1) Feature descriptive statistics ----------\n",
        "desc = data[FEATURES].describe(percentiles=[0.5]).T  # count,mean,std,min,50%,max\n",
        "desc = desc[[\"mean\", \"std\", \"min\", \"50%\", \"max\"]]\n",
        "desc.columns = [\"Mean\", \"Std\", \"Min\", \"Median\", \"Max\"]\n",
        "desc.index.name = \"Feature\"\n",
        "print(\"FEATURE SUMMARY STATISTICS (cleaned panel)\")\n",
        "print(desc.round(4).to_string())\n",
        "print(\"\\n--- LaTeX ---\")\n",
        "print(desc.round(4).to_latex(\n",
        "    caption=\"Summary statistics of the 15 features over the cleaned panel.\",\n",
        "    label=\"tab:sumstats\", float_format=\"%.4f\"))\n",
        "\n",
        "# ---------- (2) Universe coverage by sector (if a sector map exists) ----------\n",
        "# If you have a ticker->sector mapping (e.g. a dict SECTOR_MAP or a column),\n",
        "# this builds a per-sector count. Falls back to a simple per-ticker count.\n",
        "print(\"\\nUNIVERSE COVERAGE\")\n",
        "n_names = data[\"ticker\"].nunique()\n",
        "n_weeks = data[\"date\"].nunique()\n",
        "avg_per_week = data.groupby(\"date\")[\"ticker\"].nunique().mean()\n",
        "print(f\"  Distinct names      : {n_names}\")\n",
        "print(f\"  Distinct weeks      : {n_weeks}\")\n",
        "print(f\"  Avg names per week  : {avg_per_week:.1f}\")\n",
        "\n",
        "# Per-ticker observation counts (coverage diagnostic)\n",
        "cov = (data.groupby(\"ticker\")[\"date\"].nunique()\n",
        "           .describe()[[\"min\", \"50%\", \"max\"]])\n",
        "print(f\"  Weeks-per-name      : min {cov['min']:.0f}, \"\n",
        "      f\"median {cov['50%']:.0f}, max {cov['max']:.0f}\")\n",
        "\n",
        "# Optional: if you have SECTOR_MAP = {ticker: sector}, uncomment to tabulate\n",
