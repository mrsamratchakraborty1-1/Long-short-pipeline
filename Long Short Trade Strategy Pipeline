        "import time\n",
        "\n",
        "# ── FRED API key (free, from https://fredaccount.stlouisfed.org/apikeys) ────\n",
        "FRED_API_KEY = \"\"   # <-- edit this\n",
        "\n",
        "def _fred_try(url, timeout):\n",
        "    req = urllib.request.Request(url, headers={\"User-Agent\": \"Mozilla/5.0\"})\n",
        "    with urllib.request.urlopen(req, timeout=timeout) as r:\n",
        "        return r.read().decode()\n",
        "\n",
        "def fetch_fred_csv(series_id, retries=3, timeout=60):\n",
        "    \"\"\"Fetch a FRED series as a weekly (Fri) Series.\n",
        "    Tries the official FRED API (key) first, then the public CSV endpoint,\n",
        "    with retries + a long timeout. Returns None on total failure.\"\"\"\n",
        "    import json as _json_local   # local import: independent of cell run order\n",
        "    for attempt in range(1, retries + 1):\n",
        "        # --- Method 1: official FRED API (most reliable; needs a free key) ---\n",
        "        if FRED_API_KEY and FRED_API_KEY != \"PASTE_YOUR_32_CHAR_KEY_HERE\":\n",
        "            try:\n",
        "                url = (f\"https://api.stlouisfed.org/fred/series/observations\"\n",
        "                       f\"?series_id={series_id}&api_key={FRED_API_KEY}&file_type=json\")\n",
        "                obs = _json_local.loads(_fred_try(url, timeout))[\"observations\"]\n",
        "                s = pd.DataFrame(obs)[[\"date\", \"value\"]]\n",
        "                s[\"date\"] = pd.to_datetime(s[\"date\"])\n",
        "                s[\"value\"] = pd.to_numeric(s[\"value\"], errors=\"coerce\")\n",
        "                s = s.set_index(\"date\")[\"value\"].resample(FREQ).last()\n",
        "                return s\n",
        "            except Exception as e:\n",
        "                print(f\"  [warn] FRED API {series_id} attempt {attempt}/{retries} \"\n",
        "                      f\"failed ({e}); trying CSV endpoint.\")\n",
        "\n",
        "        # --- Method 2: public CSV endpoint (no key; can be slow / 403) ---\n",
        "        try:\n",
        "            url = f\"https://fred.stlouisfed.org/graph/fredgraph.csv?id={series_id}\"\n",
        "            s = pd.read_csv(io.StringIO(_fred_try(url, timeout)))\n",
        "            s.columns = [\"date\", \"value\"]\n",
        "            s[\"date\"] = pd.to_datetime(s[\"date\"])\n",
        "            s[\"value\"] = pd.to_numeric(s[\"value\"], errors=\"coerce\")\n",
        "            s = s.set_index(\"date\")[\"value\"].resample(FREQ).last()\n",
        "            return s\n",
        "        except Exception as e:\n",
        "            print(f\"  [warn] FRED {series_id} attempt {attempt}/{retries} failed ({e}).\")\n",
        "\n",
        "        if attempt < retries:\n",
        "            time.sleep(3)\n",
        "    print(f\"  [warn] FRED {series_id} unavailable after {retries} attempts; using fallback.\")\n",
        "    return None\n",
        "\n",
        "def fetch_yahoo_yield(symbol):\n",
        "    \"\"\"Fallback yield source via Yahoo. ^TNX = 10y, ^FVX = 5y (in % x10, e.g. 42.5 = 4.25%).\n",
        "    Returns a weekly (Fri) Series in percent, or None on failure.\"\"\"\n",
        "    try:\n",
        "        y = yf.download(symbol, start=START, end=END,\n",
        "                        auto_adjust=False, progress=False)[\"Close\"]\n",
        "        w = y.resample(FREQ).last()\n",
        "        if isinstance(w, pd.DataFrame):\n",
        "            w = w.iloc[:, 0]\n",
        "        return (w / 10.0)   # Yahoo quotes these as yield x10\n",
        "    except Exception as e:\n",
        "        print(f\"  [warn] Yahoo yield {symbol} failed ({e}).\")\n",
        "        return None\n",
        "\n",
        "\n",
        "# ── VIX (volatility regime) via Yahoo ───────────────────────────────────────\n",
        "print(\"Downloading macro data ...\")\n",
        "try:\n",
        "    vix_daily = yf.download(\"^VIX\", start=START, end=END,\n",
        "                            auto_adjust=False, progress=False)[\"Close\"]\n",
        "    vix_weekly = vix_daily.resample(FREQ).last()\n",
        "    if isinstance(vix_weekly, pd.DataFrame):\n",
        "        vix_weekly = vix_weekly.iloc[:, 0]\n",
        "    vix_weekly = vix_weekly.rename(\"vix\")\n",
        "    print(f\"  VIX: {vix_weekly.notna().sum()} weekly obs\")\n",
        "except Exception as e:\n",
        "    print(f\"  [warn] VIX download failed ({e}); using realized-vol proxy.\")\n",
        "    vix_weekly = (benchmark_ret.rolling(4).std() * np.sqrt(52) * 100).rename(\"vix\")\n",
        "\n",
        "# ── Yield-curve slope: 10y minus 2y ─────────────────────────────────────────\n",
        "# Method 1: FRED T10Y2Y (the slope directly).\n",
        "import os\n",
        "T10Y2Y_PATH = \"/content/drive/MyDrive/T10Y2Y.csv\"   # <- your exact path from `find`\n",
        "slope = None\n",
        "if os.path.exists(T10Y2Y_PATH):\n",
        "    _s = pd.read_csv(T10Y2Y_PATH)\n",
        "    _s.columns = [\"date\", \"value\"]                            # force-rename FRED's headers\n",
        "    _s[\"date\"] = pd.to_datetime(_s[\"date\"])\n",
        "    _s[\"value\"] = pd.to_numeric(_s[\"value\"], errors=\"coerce\")  # '.' holidays -> NaN\n",
        "    slope = _s.set_index(\"date\")[\"value\"].resample(FREQ).last()\n",
        "    print(f\"  yield_slope loaded from {T10Y2Y_PATH}\")\n",
        "\n",
        "if slope is None:\n",
        "    slope = fetch_fred_csv(\"T10Y2Y\")\n",
        "\n",
        "# Method 2: FRED DGS10 - DGS2.\n",
        "if slope is None:\n",
        "    dgs10, dgs2 = fetch_fred_csv(\"DGS10\"), fetch_fred_csv(\"DGS2\")\n",
        "    if dgs10 is not None and dgs2 is not None:\n",
        "        slope = dgs10 - dgs2\n",
        "\n",
        "# Method 3: Yahoo proxy 10y(^TNX) - 5y(^FVX). Not identical to 10y-2y, but a\n",
        "# valid term-structure slope that captures the same rate-regime signal.\n",
        "if slope is None:\n",
        "    print(\"  [info] FRED unavailable; using Yahoo 10y-5y as a yield-slope proxy.\")\n",
        "    tnx, fvx = fetch_yahoo_yield(\"^TNX\"), fetch_yahoo_yield(\"^FVX\")\n",
        "    if tnx is not None and fvx is not None:\n",
        "        slope = (tnx - fvx)\n",
        "\n",
        "# Method 4: last resort, neutral zeros (feature is then flat; ablation will show it).\n",
        "if slope is None:\n",
        "    print(\"  [warn] No yield data anywhere; yield-slope feature set to 0 (neutral).\")\n",
        "    slope = pd.Series(0.0, index=prices_weekly.index)\n",
        "\n",
        "slope = slope.reindex(prices_weekly.index).ffill().rename(\"yield_slope\")\n",
        "\n",
        "macro = pd.concat([vix_weekly.reindex(prices_weekly.index).ffill(),\n",
        "                   slope], axis=1)\n",
        "macro.index.name = \"date\"\n",
        "\n",
        "# Sanity check: is the yield-slope feature actually populated (not all zeros)?\n",
        "_nz = (macro[\"yield_slope\"] != 0).mean()\n",
        "print(f\"Macro frame: {macro.shape[0]} weeks x {macro.shape[1]} cols \"\n",
        "      f\"({list(macro.columns)})\")\n",
        "print(f\"  yield_slope non-zero share: {_nz:.2f}  \"\n",
        "      f\"({'OK - real data' if _nz > 0.5 else 'WARNING - mostly zeros (fallback)'})\")\n",
        "macro.tail(3)"
      ]
