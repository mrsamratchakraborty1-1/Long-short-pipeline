        "def download_yf(tickers, start, end=None):\n",
        "    \"\"\"Download split/dividend-adjusted close + volume from Yahoo Finance.\"\"\"\n",
        "    df = yf.download(tickers, start=start, end=end,\n",
        "                     auto_adjust=True, progress=False, threads=True)\n",
        "    if df is None or df.empty:\n",
        "        raise RuntimeError(\"Yahoo Finance returned no data. \"\n",
        "                           \"Runtime > Restart session and re-run from top.\")\n",
        "    return df[\"Close\"].copy(), df[\"Volume\"].copy()\n",
        "\n",
        "print(\"Downloading price/volume data ...\")\n",
        "prices_daily, volume_daily = download_yf(TICKERS + [BENCHMARK], START, END)\n",
        "\n",
        "# Drop any ticker that failed to download entirely\n",
        "good = prices_daily.columns[prices_daily.notna().any()].tolist()\n",
        "prices_daily = prices_daily[good]\n",
        "volume_daily = volume_daily[[c for c in good if c in volume_daily.columns]]\n",
        "TICKERS = [t for t in TICKERS if t in good and t != BENCHMARK]\n",
        "\n",
        "print(f\"Downloaded {prices_daily.shape[0]} daily rows x {prices_daily.shape[1]} series\")\n",
        "print(f\"Usable tickers after download: {len(TICKERS)}\")\n",
        "\n",
        "# Resample to weekly Friday close\n",
        "prices_weekly  = prices_daily.resample(FREQ).last()\n",
        "volume_weekly  = volume_daily.resample(FREQ).sum()\n",
        "returns_weekly = prices_weekly.pct_change()\n",
        "\n",
        "benchmark_ret  = returns_weekly[BENCHMARK].rename(\"ret_bench\")\n",
        "returns_assets = returns_weekly.drop(columns=[BENCHMARK])\n",
        "prices_assets  = prices_weekly.drop(columns=[BENCHMARK])\n",
        "volume_assets  = volume_weekly.drop(columns=[BENCHMARK])\n",
        "\n",
        "print(f\"Weekly observations: {prices_weekly.shape[0]} weeks \"\n",
        "      f\"({prices_weekly.index.min().date()} -> {prices_weekly.index.max().date()})\")"
      ]
