      "source": [
        "## 9. Walk-forward backtest (expanding window, quarterly refit)\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "Cyb9smzrI_Mj",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Cyb9smzrI_Mj",
        "outputId": "71e6cad1-2ad4-4d78-c81b-086f3edcc8f7"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "walk_forward_backtest() + analytic re-scoring helpers defined.\n"
          ]
        }
      ],
      "source": [
        "def walk_forward_backtest(data, models, features, q=0.20, long_short=True,\n",
        "                          refit_every_weeks=13, min_train_weeks=156,\n",
        "                          cost_bps=5, verbose=True, store_scores=True):\n",
        "    \"\"\"Single walk-forward pass per model. Always stores per-week scores, weights,\n",
        "    gross return and turnover so that cost sensitivity and quantile robustness can be\n",
        "    recomputed analytically WITHOUT refitting (major speed-up).\"\"\"\n",
        "    results = {}\n",
        "    dates = np.array(sorted(data[\"date\"].unique()))\n",
        "    n = len(dates)\n",
        "    if n <= min_train_weeks + 52:\n",
        "        raise ValueError(f\"Only {n} weeks; need > {min_train_weeks+52}.\")\n",
        "\n",
        "    if verbose:\n",
        "        print(f\"Walk-forward dates:\")\n",
        "        print(f\"  Initial training: {pd.Timestamp(dates[0]).date()} -> \"\n",
        "              f\"{pd.Timestamp(dates[min_train_weeks-1]).date()} ({min_train_weeks} wks)\")\n",
        "        print(f\"  Out-of-sample   : {pd.Timestamp(dates[min_train_weeks]).date()} -> \"\n",
        "              f\"{pd.Timestamp(dates[-1]).date()} ({n-min_train_weeks} wks)\")\n",
        "        itr = data[data[\"date\"].isin(dates[:min_train_weeks])]\n",
        "        oos = data[data[\"date\"].isin(dates[min_train_weeks:])]\n",
        "        print(f\"  +ve rate (train/OOS): {itr['target_up'].mean():.3f} / {oos['target_up'].mean():.3f}\")\n",
        "\n",
        "    by_date = {d: data[data[\"date\"] == d].set_index(\"ticker\") for d in dates}\n",
        "\n",
        "    for mname, model in models.items():\n",
        "        if verbose: print(f\"  running {mname} ...\")\n",
        "        pg, pn, tol, last_fit = [], [], [], None\n",
        "        w_prev, r_prev = pd.Series(dtype=float), None\n",
        "        score_log = []\n",
        "        for ti in range(min_train_weeks, n - 1):\n",
        "            t = dates[ti]\n",
        "            train = data[data[\"date\"] < t]\n",
        "            if (last_fit is None) or (ti - last_fit >= refit_every_weeks):\n",
        "                model.fit(train[features], train[\"target_up\"]); last_fit = ti\n",
        "            cur = by_date[t]\n",
        "            sc = pd.Series(model.predict_proba(cur[features])[:, 1], index=cur.index)\n",
        "            w = build_weights(sc, q=q, long_short=long_short)\n",
        "            r_hold = cur[\"ret_fwd1\"]\n",
        "            r_g = (w.reindex(r_hold.index).fillna(0) * r_hold).sum()\n",
        "            w_pp = pd.Series(0.0, index=w.index) if len(w_prev)==0 else drift_weights(w_prev, r_prev)\n",
        "            to = turnover_one_way(w, w_pp)\n",
        "            r_n = r_g - to * (cost_bps / 1e4)\n",
        "            rd = dates[ti + 1]\n",
        "            pg.append((rd, r_g)); pn.append((rd, r_n)); tol.append((rd, to))\n",
        "            if store_scores:\n",
        "                score_log.append((t, sc.copy(), w.copy(), r_hold.copy()))\n",
        "            w_prev, r_prev = w.copy(), r_hold.copy()\n",
        "        sg = pd.Series(dict(pg)).sort_index().rename(\"gross\")\n",
        "        sn = pd.Series(dict(pn)).sort_index().rename(\"net\")\n",
        "        st = pd.Series(dict(tol)).sort_index().rename(\"turnover\")\n",
        "        results[mname] = {\"gross\": sg, \"net\": sn, \"turnover\": st,\n",
        "                          \"tear_sheet\": tear_sheet(sg, sn, st, mname),\n",
        "                          \"scores\": score_log}\n",
        "    return results\n",
        "\n",
        "\n",
        "def net_at_cost(res_obj, cost_bps):\n",
        "    \"\"\"Recompute net series at an arbitrary cost from stored gross & turnover.\n",
        "    No refitting required.\"\"\"\n",
        "    return (res_obj[\"gross\"] - res_obj[\"turnover\"] * (cost_bps / 1e4)).rename(\"net\")\n",
        "\n",
        "\n",
        "def rescore_quantile(res_obj, q, long_short=True, cost_bps=5):\n",
        "    \"\"\"Recompute the strategy at a different quantile cut from STORED weekly scores.\n",
        "    No refitting required (reuses the per-week predicted probabilities).\"\"\"\n",
        "    pg, tol = [], []\n",
        "    w_prev, r_prev = pd.Series(dtype=float), None\n",
        "    for (t, sc, _w_old, r_hold) in res_obj[\"scores\"]:\n",
        "        w = build_weights(sc, q=q, long_short=long_short)\n",
        "        r_g = (w.reindex(r_hold.index).fillna(0) * r_hold).sum()\n",
        "        w_pp = pd.Series(0.0, index=w.index) if len(w_prev)==0 else drift_weights(w_prev, r_prev)\n",
        "        to = turnover_one_way(w, w_pp)\n",
        "        pg.append((t, r_g)); tol.append((t, to))\n",
        "        w_prev, r_prev = w.copy(), r_hold.copy()\n",
        "    sg = pd.Series(dict(pg)).sort_index().rename(\"gross\")\n",
        "    st = pd.Series(dict(tol)).sort_index().rename(\"turnover\")\n",
        "    sn = (sg - st * (cost_bps / 1e4)).rename(\"net\")\n",
        "    return {\"gross\": sg, \"net\": sn, \"turnover\": st,\n",
        "            \"tear_sheet\": tear_sheet(sg, sn, st, \"\")}\n",
        "\n",
        "print(\"walk_forward_backtest() + analytic re-scoring helpers defined.\")"
      ]
    },
