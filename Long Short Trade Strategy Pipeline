        "# =============================================================================\n",
        "#  A3 — ADDITIONAL EVIDENCE CELLS  (drop into the notebook as NEW cells)\n",
        "# -----------------------------------------------------------------------------\n",
        "#  Run order: paste these AFTER the base backtest cell (the one that builds\n",
        "#  `base_res`) and after `data`, `MODELS`, `FEATURES`, `Q`, `LONG_SHORT`,\n",
        "#  `REFIT_EVERY_WEEKS`, `MIN_TRAIN_WEEKS`, `COST_BPS_BASE`, `walk_forward_backtest`,\n",
        "#  `tear_sheet`, `build_weights`, `sharpe`, `ann_return` already exist.\n",
        "#\n",
        "#  Each block is self-contained, prints a clean table, and (where useful) saves\n",
        "#  a 300-dpi PNG next to the notebook for the report.\n",
        "# =============================================================================\n",
        "NAVY, RED, GREY, GREEN = \"#1f3b73\", \"#c0392b\", \"#7f8c8d\", \"#27ae60\"\n",
        "\n",
        "\n",
        "# =============================================================================\n",
        "#  CELL A — FALSIFICATION / PLACEBO TEST  (shuffled labels)\n",
        "# -----------------------------------------------------------------------------\n",
        "#  Logic: permute the week-t+1 target WITHIN each week. This destroys the\n",
        "#  feature->label relationship while preserving (i) the cross-sectional return\n",
        "#  structure used to form the portfolio and (ii) the class balance each week.\n",
        "#  If the 0.36 net Sharpe is real signal, the placebo Sharpe should collapse to\n",
        "#  ~0. We run ONE labelled placebo for the main text, then 10 repeats for an\n",
        "#  appendix distribution + an empirical p-value.\n",
        "#\n",
        "#  NOTE on mechanics: build_weights ranks on model probabilities; the realised\n",
        "#  return r_hold is the TRUE next-week return. We only shuffle the *training\n",
        "#  label* so the model learns noise. The held-out P&L still uses real returns,\n",
        "#  so a real signal survives and a fake one washes out. We implement this by\n",
        "#  shuffling `target_up` within each date on a COPY of `data`, then re-running.\n",
        "# =============================================================================\n",
        "def shuffle_targets_within_week(df, seed):\n",
        "    \"\"\"Return a copy of df with target_up permuted within each date (week).\"\"\"\n",
        "    rng = np.random.default_rng(seed)\n",
        "    out = df.copy()\n",
        "    # shuffle the target within each week so class balance per week is preserved\n",
        "    out[\"target_up\"] = (\n",
        "        out.groupby(\"date\")[\"target_up\"]\n",
        "           .transform(lambda s: s.to_numpy()[rng.permutation(len(s))])\n",
        "    )\n",
        "    return out\n",
        "\n",
        "ABLA_MODEL = \"LogReg\"   # the production model\n",
        "\n",
        "# --- True (real-label) Sharpe for reference ---\n",
        "real_sharpe = base_res[ABLA_MODEL][\"tear_sheet\"][\"Sharpe_net\"]\n",
        "\n",
        "# --- One labelled placebo run (for the main-text sentence) ---\n",
        "placebo_data_1 = shuffle_targets_within_week(data, seed=12345)\n",
        "placebo_res_1 = walk_forward_backtest(\n",
        "    placebo_data_1, {ABLA_MODEL: MODELS[ABLA_MODEL]}, FEATURES,\n",
        "    q=Q, long_short=LONG_SHORT, refit_every_weeks=REFIT_EVERY_WEEKS,\n",
        "    min_train_weeks=MIN_TRAIN_WEEKS, cost_bps=COST_BPS_BASE, verbose=False\n",
        ")\n",
        "placebo_sharpe_1 = placebo_res_1[ABLA_MODEL][\"tear_sheet\"][\"Sharpe_net\"]\n",
        "\n",
        "print(\"FALSIFICATION (PLACEBO) TEST — single shuffled-label run\")\n",
        "print(f\"  Real-label net Sharpe    : {real_sharpe:+.3f}\")\n",
        "print(f\"  Placebo  net Sharpe      : {placebo_sharpe_1:+.3f}\")\n",
        "print(f\"  -> single-run gap = {real_sharpe - placebo_sharpe_1:+.3f}; \"\n",
        "      f\"a single shuffle is high-variance -- see the 10-run distribution below for the inference.\")\n",
        "# --- 10-run placebo distribution (for the appendix) ---\n",
        "N_PLACEBO = 10\n",
        "placebo_sharpes = []\n",
        "for k in range(N_PLACEBO):\n",
        "    pdat = shuffle_targets_within_week(data, seed=1000 + k)\n",
        "    pres = walk_forward_backtest(\n",
        "        pdat, {ABLA_MODEL: MODELS[ABLA_MODEL]}, FEATURES,\n",
        "        q=Q, long_short=LONG_SHORT, refit_every_weeks=REFIT_EVERY_WEEKS,\n",
        "        min_train_weeks=MIN_TRAIN_WEEKS, cost_bps=COST_BPS_BASE, verbose=False\n",
        "    )\n",
        "    s = pres[ABLA_MODEL][\"tear_sheet\"][\"Sharpe_net\"]\n",
        "    placebo_sharpes.append(s)\n",
        "    print(f\"  placebo run {k+1:>2}: net Sharpe = {s:+.3f}\")\n",
        "\n",
        "placebo_sharpes = np.array(placebo_sharpes)\n",
        "# empirical one-sided p-value: how often does noise match/beat the real signal?\n",
        "emp_p = (np.sum(placebo_sharpes >= real_sharpe) + 1) / (N_PLACEBO + 1)\n",
        "print(f\"\\n  Placebo mean Sharpe      : {placebo_sharpes.mean():+.3f} \"\n",
        "      f\"(sd {placebo_sharpes.std():.3f})\")\n",
        "print(f\"  Real-label Sharpe        : {real_sharpe:+.3f}\")\n",
        "print(f\"  Empirical one-sided p    : {emp_p:.3f}  \"\n",
        "      f\"(fraction of noise runs >= real)\")\n",
        "\n",
        "# --- Figure: placebo distribution vs real ---\n",
        "fig, ax = plt.subplots(figsize=(8, 4))\n",
        "ax.hist(placebo_sharpes, bins=8, color=GREY, alpha=0.7,\n",
        "        label=f\"Placebo runs (n={N_PLACEBO})\")\n",
        "ax.axvline(placebo_sharpes.mean(), color=\"black\", ls=\":\", lw=1.2,\n",
        "           label=f\"Placebo mean = {placebo_sharpes.mean():+.2f}\")\n",
        "ax.axvline(real_sharpe, color=RED, lw=2.0,\n",
        "           label=f\"Real-label Sharpe = {real_sharpe:+.2f}\")\n",
        "ax.set_xlabel(\"Out-of-sample net Sharpe\")\n",
        "ax.set_ylabel(\"Frequency\")\n",
        "ax.set_title(\"Falsification test — real signal vs shuffled-label placebos\",\n",
        "             fontweight=\"bold\", loc=\"left\")\n",
        "ax.legend(frameon=False, fontsize=9)\n",
        "ax.spines[[\"top\", \"right\"]].set_visible(False)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"fig5_placebo.png\", dpi=300, bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "print(\"Saved fig5_placebo.png\")\n",
        "\n",
        "\n",
        "# =============================================================================\n",
        "#  CELL B — REBALANCING / REFIT-FREQUENCY SENSITIVITY\n",
        "# -----------------------------------------------------------------------------\n",
        "#  Directly answers the A2 feedback (\"does not examine rebalancing-frequency\n",
        "#  sensitivity\"). We re-fit the baseline at 4-week (monthly), 13-week (quarterly,\n",
        "#  base) and 26-week (semi-annual) refit schedules and compare net Sharpe,\n",
        "#  turnover and MDD. Portfolio is still re-formed WEEKLY; only the model REFIT\n",
        "#  cadence changes — which is the realistic operational lever.\n",
        "# =============================================================================\n",
        "REFIT_GRID = [4, 13, 26]\n",
        "refit_rows = []\n",
        "for rf in REFIT_GRID:\n",
        "    res = walk_forward_backtest(\n",
        "        data, {ABLA_MODEL: MODELS[ABLA_MODEL]}, FEATURES,\n",
        "        q=Q, long_short=LONG_SHORT, refit_every_weeks=rf,\n",
        "        min_train_weeks=MIN_TRAIN_WEEKS, cost_bps=COST_BPS_BASE, verbose=False\n",
        "    )\n",
        "    ts = res[ABLA_MODEL][\"tear_sheet\"]\n",
        "    refit_rows.append({\n",
        "        \"Refit (weeks)\": rf,\n",
        "        \"Cadence\": {4: \"Monthly\", 13: \"Quarterly (base)\", 26: \"Semi-annual\"}[rf],\n",
        "        \"Net Sharpe\": round(ts[\"Sharpe_net\"], 3),\n",
        "        \"Ann. Ret\": f\"{ts['AnnRet_net']*100:.1f}%\",\n",
        "        \"Max DD\": f\"{ts['MDD_net']*100:.1f}%\",\n",
        "        \"Turnover\": round(ts[\"AvgTurnover\"], 3),\n",
        "    })\n",
        "refit_df = pd.DataFrame(refit_rows)\n",
        "print(\"\\nREBALANCING / REFIT-FREQUENCY SENSITIVITY (LogReg, net 5 bps)\")\n",
        "print(refit_df.to_string(index=False))\n",
        "spread = refit_df[\"Net Sharpe\"].max() - refit_df[\"Net Sharpe\"].min()\n",
        "print(f\"  Net-Sharpe spread across refit cadences: {spread:.3f}  \"\n",
        "      f\"-> {'STABLE' if spread < 0.20 else 'SENSITIVE'}\")\n",
        "print(\"\\n--- LaTeX ---\")\n",
        "print(refit_df.to_latex(index=False,\n",
        "      caption=\"Refit-frequency sensitivity (baseline LogReg, net 5 bps).\",\n",
        "      label=\"tab:refit_sens\"))\n",
        "\n",
        "\n",
        "# =============================================================================\n",
        "#  CELL C — RANK INFORMATION COEFFICIENT (IC)\n",
        "# -----------------------------------------------------------------------------\n",
        "#  Tests the RANKER directly (not just portfolio P&L): each week, the rank\n",
        "#  correlation (Spearman) between predicted probability and realised next-week\n",
        "#  return. Mean IC > 0 with a positive IR (mean/sd) means the model genuinely\n",
        "#  ranks. Uses the per-week stored scores in base_res[...]['scores'].\n",
        "# =============================================================================\n",
        "from scipy.stats import spearmanr\n",
        "\n",
        "log = base_res[ABLA_MODEL][\"scores\"]   # list of (date, scores, weights, r_hold)\n",
        "ic_series = []\n",
        "for t, sc, w, rh in log:\n",
        "    common = sc.index.intersection(rh.dropna().index)\n",
        "    if len(common) >= 10:\n",
        "        ic, _ = spearmanr(sc.reindex(common), rh.reindex(common))\n",
        "        ic_series.append((t, ic))\n",
        "ic_series = pd.Series(dict(ic_series)).sort_index()\n",
        "\n",
        "mean_ic = ic_series.mean()\n",
        "ic_ir = mean_ic / ic_series.std()                 # information ratio of the IC\n",
        "ic_t = mean_ic / (ic_series.std() / np.sqrt(len(ic_series)))\n",
        "hit = (ic_series > 0).mean()\n",
        "\n",
        "print(\"\\nRANK INFORMATION COEFFICIENT (LogReg)\")\n",
        "print(f\"  Weeks evaluated      : {len(ic_series)}\")\n",
        "print(f\"  Mean weekly rank IC  : {mean_ic:+.4f}\")\n",
        "print(f\"  IC info-ratio (IR)   : {ic_ir:+.3f}\")\n",
        "print(f\"  IC t-statistic       : {ic_t:+.2f}\")\n",
        "print(f\"  % weeks IC > 0        : {hit*100:.1f}%\")\n",
        "\n",
        "# Rolling IC figure\n",
        "roll_ic = ic_series.rolling(26).mean()\n",
        "fig, ax = plt.subplots(figsize=(10, 3.8))\n",
        "ax.bar(ic_series.index, ic_series.values, width=5, color=GREY, alpha=0.45,\n",
        "       label=\"Weekly rank IC\")\n",
        "ax.plot(roll_ic.index, roll_ic.values, color=NAVY, lw=1.8,\n",
        "        label=\"26-week rolling mean IC\")\n",
        "ax.axhline(0, color=\"black\", lw=0.8)\n",
        "ax.axhline(mean_ic, color=RED, ls=\"--\", lw=1.1,\n",
        "           label=f\"Full-sample mean IC = {mean_ic:+.3f}\")\n",
        "ax.set_ylabel(\"Spearman rank IC\")\n",
        "ax.set_title(\"Rank information coefficient — predicted prob vs realised return\",\n",
        "             fontweight=\"bold\", loc=\"left\")\n",
        "ax.legend(frameon=False, fontsize=9, ncol=3, loc=\"upper center\")\n",
        "ax.spines[[\"top\", \"right\"]].set_visible(False)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"fig6_rank_ic.png\", dpi=300, bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "print(\"Saved fig6_rank_ic.png\")\n",
        "\n",
        "\n",
        "# =============================================================================\n",
        "#  CELL D — DIAGNOSTICS THAT WERE \"COMPUTED BUT NOT SHOWN\"\n",
        "#           (fixes the recurring A1/A2 surfacing criticism)\n",
        "# -----------------------------------------------------------------------------\n",
        "#  D1: per-rebalance turnover plot + summary (A2 said this was hidden)\n",
        "#  D2: clean first/last-5-rows dataset preview (A1 said this was missing)\n",
        "# =============================================================================\n",
        "\n",
        "# --- D1: per-rebalance turnover ---\n",
        "to_series = base_res[ABLA_MODEL][\"turnover\"]\n",
        "fig, ax = plt.subplots(figsize=(10, 3.6))\n",
        "ax.plot(to_series.index, to_series.values, color=NAVY, lw=0.9,\n",
        "        label=\"Per-rebalance one-way turnover\")\n",
        "ax.axhline(to_series.mean(), color=RED, ls=\"--\", lw=1.1,\n",
        "           label=f\"Average = {to_series.mean():.2f}\")\n",
        "ax.set_ylabel(\"One-way turnover\")\n",
        "ax.set_title(\"Per-rebalance turnover (LogReg) — trading-activity diagnostic\",\n",
        "             fontweight=\"bold\", loc=\"left\")\n",
        "ax.legend(frameon=False, fontsize=9)\n",
        "ax.spines[[\"top\", \"right\"]].set_visible(False)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"fig7_turnover.png\", dpi=300, bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "print(\"Saved fig7_turnover.png\")\n",
        "print(f\"Turnover — mean {to_series.mean():.3f}, median {to_series.median():.3f}, \"\n",
        "      f\"min {to_series.min():.3f}, max {to_series.max():.3f}\")\n",
        "\n",
        "# --- D2: dataset preview (first/last 5 rows of the cleaned panel) ---\n",
        "preview_cols = [\"date\", \"ticker\"] + FEATURES[:5] + [\"target_up\"]   # keep it readable\n",
        "preview_cols = [c for c in preview_cols if c in data.columns]\n",
        "print(\"\\nCLEANED DATASET PREVIEW — first 5 rows\")\n",
        "print(data[preview_cols].head().to_string(index=False))\n",
        "print(\"\\nCLEANED DATASET PREVIEW — last 5 rows\")\n",
        "print(data[preview_cols].tail().to_string(index=False))\n",
