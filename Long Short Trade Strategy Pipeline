        "# Per-week strategy return from stored weights\n",
        "wk = []\n",
        "for t, sc, w, rh in log:\n",
        "    wk.append((t, (w.reindex(rh.index).fillna(0) * rh).sum()))\n",
        "wk = pd.Series(dict(wk)).sort_index()\n",
        "\n",
        "# Case 1-3: three worst weeks\n",
        "worst = wk.nsmallest(3)\n",
        "print(\"ERROR ANALYSIS\")\n",
        "print(\"=\"*70)\n",
        "cases = []\n",
        "for i, (t, r) in enumerate(worst.items(), 1):\n",
        "    cases.append(f\"Case {i}: Week {pd.Timestamp(t).date()} — strategy returned {r*100:.2f}%.\")\n",
        "# Case 4: most mis-ranked single name (high score, large negative realised return)\n",
        "mis = []\n",
        "for t, sc, w, rh in log:\n",
        "    for tk in w[w>0].index:                       # longs that fell hard\n",
        "        if tk in rh.index and pd.notna(rh[tk]):\n",
        "            mis.append((t, tk, sc.get(tk, np.nan), rh[tk], \"long\"))\n",
        "    for tk in w[w<0].index:                        # shorts that rose hard\n",
        "        if tk in rh.index and pd.notna(rh[tk]):\n",
        "            mis.append((t, tk, sc.get(tk, np.nan), rh[tk], \"short\"))\n",
        "mis_df = pd.DataFrame(mis, columns=[\"date\",\"ticker\",\"score\",\"ret_fwd1\",\"leg\"])\n",
