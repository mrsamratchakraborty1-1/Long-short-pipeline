        "# =============================================================================\n",
        "# UNIVERSE  —  addresses TUTOR COMMENT 1 (universe too small: 36 -> ~100)\n",
        "# -----------------------------------------------------------------------------\n",
        "# Selection procedure (documented for the report Data section):\n",
        "#   1. Start from liquid, continuously-listed S&P 500 / large- and mid-cap names.\n",
        "#   2. Spread across 9 GICS sectors to avoid sector concentration.\n",
        "#   3. Target ~100 names so that each quintile leg (top/bottom 20%) holds ~20\n",
        "#      stocks, which the tutor flagged as the minimum for adequate diversification.\n",
        "#   4. NOTE: this is NOT a point-in-time constituent list -> survivorship bias\n",
        "#      applies and is discussed explicitly in the Limitations section.\n",
        "# =============================================================================\n",
        "TICKERS = [\n",
        "    # Technology\n",
        "    \"AAPL\",\"MSFT\",\"NVDA\",\"ORCL\",\"CSCO\",\"ADBE\",\"CRM\",\"INTC\",\"AMD\",\"TXN\",\n",
        "    \"QCOM\",\"IBM\",\"NOW\",\"INTU\",\"JNPR\",\"NTAP\",\"FFIV\",\"VRSN\",\"CDNS\",\"TER\",\n",
        "    # Healthcare\n",
        "    \"JNJ\",\"UNH\",\"PFE\",\"MRK\",\"ABBV\",\"TMO\",\"ABT\",\"DHR\",\"BMY\",\"AMGN\",\n",
        "    \"HOLX\",\"DVA\",\"HSIC\",\"MASI\",\"XRAY\",\n",
        "    # Financials\n",
        "    \"JPM\",\"BAC\",\"WFC\",\"GS\",\"MS\",\"C\",\"USB\",\"PNC\",\"SCHW\",\"AXP\",\n",
        "    \"RF\",\"FITB\",\"HBAN\",\"KEY\",\"MTB\",\"ZION\",\n",
        "    # Industrials\n",
        "    \"GE\",\"HON\",\"UPS\",\"CAT\",\"BA\",\"LMT\",\"RTX\",\"DE\",\"MMM\",\"EMR\",\n",
        "    \"AOS\",\"MAS\",\"ROL\",\"TXT\",\"HII\",\n",
        "    # Consumer Discretionary\n",
        "    \"AMZN\",\"HD\",\"MCD\",\"NKE\",\"LOW\",\"SBUX\",\"TGT\",\"BKNG\",\"TJX\",\"GM\",\n",
        "    \"LKQ\",\"TPR\",\"PVH\",\n",
        "    # Consumer Staples\n",
        "    \"PG\",\"KO\",\"PEP\",\"WMT\",\"COST\",\"CL\",\"MDLZ\",\"KMB\",\n",
        "    # Energy\n",
        "    \"XOM\",\"CVX\",\"COP\",\"SLB\",\"EOG\",\"OKE\",\"RRC\",\"SM\",\"CTRA\",\n",
        "    # Materials\n",
        "    \"LIN\",\"APD\",\"SHW\",\"NEM\",\"FCX\",\"DOW\",\"PKG\",\"OLN\",\"SON\",\n",
        "    # Utilities / Comms (diversifiers)\n",
        "    \"NEE\",\"DUK\",\"SO\",\"T\",\"VZ\",\"CMCSA\",\n",
        "]\n",
        "# De-duplicate while preserving order\n",
        "TICKERS = list(dict.fromkeys(TICKERS))\n",
        "\n",
        "BENCHMARK = \"SPY\"\n",
        "\n",
        "# =============================================================================\n",
        "# SAMPLE & WALK-FORWARD  —  addresses TUTOR COMMENT 4 (training window too short)\n",
        "# -----------------------------------------------------------------------------\n",
        "#   - Extend overall sample start earlier to give a longer history.\n",
        "#   - Lengthen initial training window 104 -> 156 weeks (3 years) so the model\n",
        "#     has a more stable basis before the first out-of-sample prediction.\n",
        "# =============================================================================\n",
        "START = \"2012-01-01\"          # earlier start -> longer history\n",
        "END   = \"2026-03-28\"\n",
        "FREQ  = \"W-FRI\"               # weekly, Friday close\n",
        "\n",
        "REFIT_EVERY_WEEKS = 13        # quarterly refit (engineering choice; documented)\n",
        "MIN_TRAIN_WEEKS   = 156       # CHANGED 104 -> 156 (3 years) per tutor comment 4\n",
        "\n",
        "# =============================================================================\n",
        "# PORTFOLIO CONSTRUCTION\n",
        "#   - addresses TUTOR COMMENT 2 (position cap redundant -> REMOVED)\n",
        "#   - With equal-weight legs and ~20 names per leg, every weight is pinned at\n",
