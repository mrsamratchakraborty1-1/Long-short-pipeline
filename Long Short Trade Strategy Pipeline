        "# ── Sentiment-availability guard (run FIRST) ────────────────────────────────\n",
        "# If the SRAF CSV was not loaded, the 5 sentiment columns are all-NaN and would\n",
        "# drop EVERY row in cleaning. Detect that here and exclude sentiment up front so\n",
        "# the feature dictionary, cleaning, and models all use the SAME feature list.\n",
        "_sent_cols_present = [c for c in SENT_FEATURES if c in df_feat.columns]\n",
        "_sent_all_nan = (len(_sent_cols_present) == 0) or df_feat[_sent_cols_present].isna().all().all()\n",
        "if _sent_all_nan:\n",
        "    print(\"[info] Sentiment data unavailable (SRAF CSV not loaded).\")\n",
        "    print(\"       -> Excluding the 5 sentiment features; running with the other 10.\")\n",
        "    print(\"       To enable sentiment: download the LM 10-X CSV (Ed #34), upload it to\")\n",
        "    print(\"       this Colab session, set LM_CSV_PATH in Section 3b, and re-run from there.\\n\")\n",
        "    FEATURES = [f for f in FEATURES if f not in SENT_FEATURES]\n",
        "\n",
        "# Feature metadata keyed by name so the table always matches FEATURES,\n",
        "# even if sentiment is excluded in fallback mode.\n",
        "FEATURE_META = {\n",
        "    \"mom_12w\":        (\"Momentum\",  \"Sum of weekly returns t-11..t\",                \"End of week t\",            \"Jegadeesh & Titman (1993)\"),\n",
        "    \"mom_26w_skip1\":  (\"Momentum\",  \"Sum of returns t-26..t-2 (skip last week)\",    \"End of week t\",            \"Intermediate momentum, skip-1\"),\n",
        "    \"high52_ratio\":   (\"Trend\",     \"Price_t / max(Price) over 52w (min 26 obs)\",   \"End of week t\",            \"George & Hwang (2004)\"),\n",
        "    \"idiovol_8w\":     (\"Risk\",      \"Std of (ret - SPY ret) over 8w\",               \"End of week t\",            \"Ang et al. (2006)\"),\n",
        "    \"amihud_4w\":      (\"Liquidity\", \"log(1+mean(|ret|/$vol)*1e9) over 4w\",          \"End of week t\",            \"Amihud (2002)\"),\n",
        "    \"vol_trend_4_12\": (\"Risk\",      \"std(ret,4w) / std(ret,12w)\",                   \"End of week t\",            \"Practitioner standard\"),\n",
        "    \"vix\":            (\"Macro\",     \"CBOE VIX level (volatility regime)\",           \"End of week t\",            \"Volatility regime\"),\n",
        "    \"yield_slope\":    (\"Macro\",     \"10y-2y Treasury slope (rate regime)\",          \"End of week t\",            \"Term-structure regime\"),\n",
        "    \"ret_rank_xsec\":  (\"Cross-sec\", \"Within-week percentile rank of mom_12w\",       \"End of week t\",            \"Cross-sectional ranking\"),\n",
        "    \"idiovol_rank_xsec\": (\"Cross-sec\",\"Within-week percentile rank of idiovol_8w\",  \"End of week t\",            \"Cross-sectional ranking\"),\n",
        "    \"sent_neg_pct\":   (\"Sentiment\", \"Negative words / N_Words (last 10-K/Q)\",       \"Last filing on/before t\",  \"Loughran-McDonald (2011)\"),\n",
        "    \"sent_pos_pct\":   (\"Sentiment\", \"Positive words / N_Words (last 10-K/Q)\",       \"Last filing on/before t\",  \"Loughran-McDonald (2011)\"),\n",
        "    \"sent_unc_pct\":   (\"Sentiment\", \"Uncertainty words / N_Words (last 10-K/Q)\",    \"Last filing on/before t\",  \"Loughran-McDonald (2011)\"),\n",
        "    \"sent_lit_pct\":   (\"Sentiment\", \"Litigious words / N_Words (last 10-K/Q)\",      \"Last filing on/before t\",  \"Loughran-McDonald (2011)\"),\n",
